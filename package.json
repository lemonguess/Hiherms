{
  "name": "hermespet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "vue-tsc -p tsconfig.web.json --noEmit",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "pinia": "^2.2.6",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "~6.5.10",
    "vue": "^3.5.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@pixi/core": "6.5.10",
      "@pixi/display": "6.5.10",
      "@pixi/math": "6.5.10",
      "@pixi/sprite": "6.5.10",
      "@pixi/utils": "6.5.10",
      "@pixi/loaders": "6.5.10",
      "@pixi/interaction": "6.5.10",
      "@pixi/ticker": "6.5.10",
      "@pixi/extensions": "6.5.10",
      "@pixi/constants": "6.5.10",
      "@pixi/settings": "6.5.10",
      "@pixi/runner": "6.5.10",
      "@pixi/events": "6.5.10"
    }
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vue-tsc": "^2.1.10"
  }
}